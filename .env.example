# Copy to .env (gitignored) and fill in only what you use.
#
# NOTE: With the Cloudflare Git integration handling deploys, you do NOT need
# Cloudflare tokens in GitHub secrets for the normal flow. These are only for
# running `wrangler` manually from your machine if you ever want to.

# Optional — only for manual `wrangler pages deploy` from local:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Figma Code Connect / personal access (if using the Figma CLI locally)
FIGMA_ACCESS_TOKEN=
