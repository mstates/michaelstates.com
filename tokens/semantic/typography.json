{
  "font": {
    "sans": { "$type": "fontFamily", "$value": "{mc.font.family.sans}" },
    "mono": { "$type": "fontFamily", "$value": "{mc.font.family.mono}" }
  },
  "text": {
    "caption": { "$type": "dimension", "$value": "{mc.size.sm}" },
    "body": { "$type": "dimension", "$value": "{mc.size.base}" },
    "title": { "$type": "dimension", "$value": "{mc.size.2xl}" },
    "display": { "$type": "dimension", "$value": "{mc.size.4xl}" }
  },
  "leading": {
    "heading": { "$type": "number", "$value": "{mc.leading.tight}" }
  }
}
