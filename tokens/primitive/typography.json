{
  "mc": {
    "font": {
      "family": {
        "sans": {
          "$type": "fontFamily",
          "$value": "'Plus Jakarta Sans', 'Plus Jakarta Sans Fallback', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
        },
        "serif": {
          "$type": "fontFamily",
          "$value": "'Newsreader', 'Newsreader Fallback', ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif"
        },
        "mono": {
          "$type": "fontFamily",
          "$value": "'Space Mono', 'Space Mono Fallback', ui-monospace, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace"
        }
      }
    },
    "size": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.125rem" },
      "xl": { "$type": "dimension", "$value": "1.25rem" },
      "2xl": { "$type": "dimension", "$value": "1.5rem" },
      "3xl": { "$type": "dimension", "$value": "1.875rem" },
      "4xl": { "$type": "dimension", "$value": "2.25rem" },
      "5xl": { "$type": "dimension", "$value": "3rem" },
      "hero-min": { "$type": "dimension", "$value": "2.75rem" },
      "hero-max": { "$type": "dimension", "$value": "4rem" }
    },
    "leading": {
      "tight": { "$type": "number", "$value": 1.15 },
      "snug": { "$type": "number", "$value": 1.3 },
      "relaxed": { "$type": "number", "$value": 1.65 }
    },
    "tracking": {
      "tight": { "$type": "dimension", "$value": "-0.01em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide": { "$type": "dimension", "$value": "0.02em" }
    }
  }
}
