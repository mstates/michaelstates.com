# Cloudflare _headers — caching + security for a static Astro site.
# Hashed assets are immutable; cache them hard. Security headers also push
# Lighthouse "Best Practices" toward 100 with zero runtime cost.

# Fingerprinted build assets never change under a given name — cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# HTML should always revalidate so deploys show up immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers applied site-wide.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  # HSTS: enforce HTTPS. Add "; preload" only once you're certain every
  # subdomain is HTTPS-only — preload is hard to reverse.
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Noindex every *.pages.dev host — the bare production alias and all preview
# hosts. Host-scoped on purpose: the literal ".pages.dev" suffix in the matcher
# makes these rules structurally inert on the custom domain after the Stage 8
# cutover, even though this file ships with every build. INC-235 / audit P5.
https://:project.pages.dev/*
  X-Robots-Tag: noindex

https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex
