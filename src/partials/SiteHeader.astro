---
// INC-250: site header, extracted verbatim from src/pages/index.astro (INC-243 shell).
// Zero-hydration by contract (B4): every interactive element is a native link; no
// client:* directives, no <style>/<script> blocks. Byte-parity discipline: the template
// is a verbatim copy (text-node line structure matters under compressHTML) — commentary
// stays in frontmatter, never in the template.
import { pillPrimary } from './recipes';

const navLink = 'inline-flex min-h-6 items-center text-body font-semibold text-foreground hover:underline';
---

<header class="sticky top-0 z-40 border-b border-border bg-background">
	<nav
		aria-label="Primary"
		class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-6 gap-y-2 px-6 py-4 sm:px-10"
	>
		<a href="/" class="inline-flex min-h-6 items-center gap-2.5 text-body font-bold text-foreground">
			<span aria-hidden="true" class="size-6 rounded-md bg-accent"></span>
			Michael States
		</a>
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			<a href="#work" class={navLink}>Work</a>
			<a href="#services" class={navLink}>Services</a>
			<a href="#about" class={navLink}>About</a>
			<a href="#contact" class={`${pillPrimary} px-5 py-2.5`}>Work with me</a>
		</div>
	</nav>
</header>
