---
// INC-251: case-card tag pill, extracted verbatim from src/pages/index.astro (INC-243
// shell). Zero-hydration by contract (B4): no client:* directives, no <style>/<script>
// blocks. Byte-parity discipline: the template is a verbatim copy (text-node line
// structure matters under compressHTML) — commentary stays in frontmatter, never in
// the template.
interface Props {
	tag: string;
}

const { tag } = Astro.props;
---

<span class="rounded-full border border-border px-3 py-1 font-mono text-caption text-muted-foreground">
	{tag}
</span>
