---
// INC-251: placeholder case-study route proving the article infrastructure —
// CaseStudyLayout, the prose layer, accessible Shiki code blocks, and KeyTakeaways.
// Copy is deliberately lorem-level; real case-study content ships with INC-248.
// Zero-hydration by contract (B4): no client:* directives, no React/RAC.
import { Code } from 'astro:components';
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import KeyTakeaways from '../../partials/KeyTakeaways.astro';

const sampleCode = `// Respect the user's motion preference before animating.
const query = window.matchMedia('(prefers-reduced-motion: reduce)');

export function motionSafe(animate: () => void): void {
	if (!query.matches) {
		animate();
	}
}`;
---

<CaseStudyLayout
	title="Sample case study"
	description="A placeholder case study demonstrating the article infrastructure — prose styles, accessible code blocks, and key takeaways."
>
	<h1>Sample case study</h1>
	<p>
		This is a placeholder article that exercises every element of the case-study prose layer.
		The copy is intentionally generic; the structure, spacing, and color contracts underneath it
		are the real deliverable.
	</p>

	<h2>The problem</h2>
	<p>
		Placeholder framing of a design problem, written at roughly the length a real opening
		paragraph would run. It exists so the flow rhythm between headings, paragraphs, and lists
		can be judged against real line lengths.
	</p>
	<ul>
		<li>A first constraint, stated in a single sentence.</li>
		<li>A second constraint that wraps onto a second line at the article measure, so list item spacing is visible.</li>
		<li>A third constraint.</li>
	</ul>

	<h2>The approach</h2>
	<p>
		Placeholder description of the approach, including an inline code reference like
		<code>prefers-reduced-motion</code> to exercise the light chip treatment inside body text.
	</p>
	<ol>
		<li>Audit the existing behavior.</li>
		<li>Fix the pattern at the system level.</li>
		<li>Verify with assistive technology.</li>
	</ol>

	<blockquote>
		<p>A plain block quotation, unattributed, for editorial asides pulled from the narrative.</p>
	</blockquote>

	<figure>
		<blockquote>
			<p>An attributed quotation — the variant a real case study uses for stakeholder or user quotes.</p>
		</blockquote>
		<figcaption>— Placeholder Name, research participant</figcaption>
	</figure>

	<h3>A code sample</h3>
	<figure>
		<Code
			code={sampleCode}
			lang="ts"
			theme="css-variables"
			tabindex="0"
			role="region"
			aria-label="Code sample: motion-safe animation helper"
		/>
		<figcaption>Listing: a motion-safe animation helper (placeholder).</figcaption>
	</figure>

	<KeyTakeaways
		items={[
			'First placeholder takeaway, one sentence long.',
			'Second placeholder takeaway, also one sentence.',
			'Third placeholder takeaway to fill out the list.',
		]}
	/>
</CaseStudyLayout>
