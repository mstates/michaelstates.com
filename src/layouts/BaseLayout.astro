---
import '../styles/global.css';

// Named slots (INC-243): "header" renders between the skip link and <main> so a page
// header lands outside main with its native banner role; "footer" renders after
// </main> (contentinfo). Both are placed flush against the adjacent tags because an
// unfilled slot must emit zero bytes — pages that don't use them (404) keep
// byte-identical output.
interface Props {
	/** Page title; rendered as `${title} · Michael States` unless titleSuffix is false. */
	title: string;
	/** One-sentence page summary; feeds meta description and og:description. */
	description: string;
	/** Append the "· Michael States" suffix (homepage opts out with a bare site-name title). */
	titleSuffix?: boolean;
	/** Absolute canonical URL override; defaults to this page's URL on Astro.site. */
	canonical?: string;
	/** Open Graph object type. */
	ogType?: string;
	/** Classes applied to the layout-owned <main> (page-specific layout). */
	mainClass?: string;
}

const {
	title,
	description,
	titleSuffix = true,
	canonical,
	ogType = 'website',
	mainClass,
} = Astro.props;

const fullTitle = titleSuffix ? `${title} · Michael States` : title;
// Astro.site is set in astro.config.mjs. In the static build Astro.url.pathname is the
// route's final path under build.format 'directory' ('/' for index, '/404/' for 404).
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<!-- Above-the-fold brand faces only (INC-242 / ADR 0008): Newsreader 500
		     (hero/headings), Jakarta 400 (body), Space Mono 700 (eyebrow).
		     crossorigin is required for font preloads even same-origin. -->
		<link
			rel="preload"
			href="/fonts/newsreader-latin-500-normal-v5.2.10.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/plus-jakarta-sans-latin-400-normal-v5.2.8.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/space-mono-latin-700-normal-v5.2.9.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content={ogType} />
		<!-- og:image intentionally absent — ships with INC-208. -->
	</head>
	<body class="bg-background text-foreground">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-2 focus:top-2 focus:z-50 focus:inline-flex focus:min-h-6 focus:items-center focus:rounded-sm focus:border focus:border-border focus:bg-background focus:px-4 focus:py-2 focus:text-body focus:text-foreground focus:underline"
		>
			Skip to main content
		</a><slot name="header" />
		<main id="main" tabindex="-1" class={mainClass}>
			<slot />
		</main><slot name="footer" />
	</body>
</html>
