{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "description": "Bleeding-edge, accessibility-first portfolio built with Astro, React Aria, and a Claude Code studio.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "tokens": "style-dictionary build --config style-dictionary.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test --config playwright.a11y.config.ts",
    "lint": "eslint . && astro check",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "_comment": "Dependencies are pinned all-exact (no caret ranges) by deliberate decision — edit versions explicitly and treat the pnpm lockfile as authoritative; this project does not use `astro add` / range resolution. The scripts below are the command contract the studio expects — do not remove them; some tools (eslint, vitest, Playwright + axe, lhci) are installed at SETUP.md Stage 6.",
  "dependencies": {
    "@astrojs/react": "5.0.7",
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.1",
    "astro": "6.4.8",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.4",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@tokens-studio/sd-transforms": "2.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "astro-eslint-parser": "1.4.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "storybook": "10.4.6",
    "style-dictionary": "5.5.0",
    "tailwindcss-react-aria-components": "2.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
